root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{sln,vcxproj,vcxproj.filters,csproj,props,targets,ps1}]
end_of_line = crlf

[*.{md,txt}]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[*.{cpp,cxx,cc,c,h,hpp,hh}]
indent_size = 4

[*.cs]
indent_size = 4
