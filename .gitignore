# Third-party vendored sources: the rules above (x86/, ARM/, Win32/) would
# otherwise eat libopus's SIMD subdirectories (celt/x86, silk/arm,
# silk/fixed/arm, etc.). Force them back in so the vendor tree is complete.
!third_party/libopus/**
# But still drop the per-config MSVC build leftovers if any get created
# inside the vendor tree by accident.
third_party/libopus/**/Debug/
third_party/libopus/**/Release/
third_party/libopus/**/*.obj
third_party/libopus/**/*.pdb
third_party/libopus/**/*.tlog
