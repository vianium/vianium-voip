  <ItemGroup>
    <ProjectReference Include="Vianium.Tgcalls.vcxproj">
      <Project>{f7a8b9c0-d1e2-4f3a-9b0c-1d2e3f4a5b6c}</Project>
      <Private>false</Private>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
    </ProjectReference>
    <ProjectReference Include="$(ProjectDir)..\vianium-kernel\Vianium.Core.Kernel.vcxproj">
      <Project>{c9d0e1f2-a3b4-4c5d-6e7f-8a9b0c1d2e3f}</Project>
      <Private>false</Private>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
    </ProjectReference>
    <!-- Vianium.Core.Crypto and Vianium.Core.Tls expose the AES/SHA/BigNum/
         ECDH/HMAC/TLS-PRF primitives used by voip_engine, dtls_client_session,
         srtp_packet_codec, stun_message and tgcalls_signaling_codec. Both
         must be linked into Vianium.VoIP.dll (LinkLibraryDependencies=true,
         which is the default — kept explicit here so a future edit doesn't
         silently drop the link). -->
    <ProjectReference Include="$(ProjectDir)..\vianium-crypto\Vianium.Core.Crypto.vcxproj">
      <Project>{d1e2f3a4-b5c6-4d7e-8f9a-0b1c2d3e4f5a}</Project>
      <Private>false</Private>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <LinkLibraryDependencies>true</LinkLibraryDependencies>
    </ProjectReference>
    <ProjectReference Include="$(ProjectDir)..\vianium-tls\Vianium.Core.Tls.vcxproj">
      <Project>{b8c9d0e1-f2a3-4b4c-5d6e-7f8a9b0c1d2e}</Project>
      <Private>false</Private>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <LinkLibraryDependencies>true</LinkLibraryDependencies>
      <!-- Vianium.Core.Tls is a DynamicLibrary. The functions VoIP needs
           (TlsPrf::Compute) are marked __declspec(dllexport) inside tls
           and __declspec(dllimport) for consumers via VIANIUM_TLS_PRF_API.
           DO NOT set UseLibraryDependencyInputs=true here — that would pull
           in the .obj files and conflict with the import-via-dllimport
           pattern, producing `unresolved external symbol __imp_?Compute`. -->
    </ProjectReference>
    <ProjectReference Include="third_party\libtgvoip\libtgvoip.vcxproj">
      <Project>{d6e7f8a9-b0cb-4ecf-d034-e7f8a9bbcc1d}</Project>
      <Private>false</Private>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
    </ProjectReference>
