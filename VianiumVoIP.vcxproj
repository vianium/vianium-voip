      <!-- Hand-feed Vianium.Tls.lib because ProjectReference→tls's
           LinkLibraryDependencies default does NOT inject the .lib in this
           solution layout (empirically — see link.command.1.tlog audit).
           The path uses the solution-centralised OutDir; the per-repo
           fallback is included for cmd-line builds without the .sln.
           TlsPrf::Compute is dllimport via VIANIUM_TLS_PRF_API. -->
      <AdditionalLibraryDirectories>$(SolutionDir)$(Configuration)\Vianium.Core.Tls\;$(SolutionDir)$(Platform)\$(Configuration)\Vianium.Core.Tls\;$(ProjectDir)..\vianium-tls\$(Configuration)\Vianium.Core.Tls\;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>mmdevapi.lib;runtimeobject.lib;Vianium.Tls.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <GenerateWindowsMetadata>true</GenerateWindowsMetadata>
    </Link>
  </ItemDefinitionGroup>
