  <ItemGroup Label="Audio">
    <!-- Resampler is the only platform-neutral audio source we can compile.    -->
    <!-- AudioIO / AudioInput / AudioOutput / AudioIOCallback are EXCLUDED:     -->
    <!--   they pull in MMSYSTEM (waveOut*) which is not available under        -->
    <!--   WINAPI_FAMILY_PHONE_APP, plus enumerate WASAPI device IDs that VS2013 -->
    <!--   does not surface in the WP8.1 SDK. See VENDORING_NOTES.md.           -->
    <ClCompile Include="src\audio\Resampler.cpp" />
    <ClCompile Include="src\audio\AudioIO.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\audio\AudioIOCallback.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\audio\AudioInput.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\audio\AudioOutput.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
  </ItemGroup>
  <ItemGroup Label="AudioHeaders">
    <ClInclude Include="src\audio\AudioIO.h" />
    <ClInclude Include="src\audio\AudioIOCallback.h" />
    <ClInclude Include="src\audio\AudioInput.h" />
    <ClInclude Include="src\audio\AudioOutput.h" />
    <ClInclude Include="src\audio\Resampler.h" />
  </ItemGroup>
  <ItemGroup Label="Video">
    <!-- Video subdirectory uses C++14 features (constexpr namespace-scope      -->
    <!-- definitions) that v120_wp81 (VS2013) does not parse. We do not need    -->
    <!-- video for the WP8.1 voice-call use case anyway. The .h files are       -->
    <!-- still compiled transitively from VoIPController.h but that path only   -->
    <!-- needs the class declarations, which parse fine. See VENDORING_NOTES.md -->
    <ClCompile Include="src\video\ScreamCongestionController.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\video\VideoRenderer.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\video\VideoSource.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
  </ItemGroup>
  <ItemGroup Label="VideoHeaders">
    <ClInclude Include="src\video\ScreamCongestionController.h" />
    <ClInclude Include="src\video\VideoRenderer.h" />
    <ClInclude Include="src\video\VideoSource.h" />
  </ItemGroup>
  <ItemGroup Label="OsWindows">
    <!-- NetworkSocketWinsock and WindowsSpecific compile cleanly under         -->
    <!-- WINAPI_FAMILY_PHONE_APP. The other os/windows/*.cpp files require      -->
    <!-- legacy MMSYSTEM (waveOut*) or WASAPI flags absent from the WP8.1 SDK   -->
    <!-- (AUDCLNT_STREAMFLAGS_AUTOCONVERTPCM / IAudioClient2 activation), so    -->
    <!-- they are excluded for now. CXWrapper additionally has VS2013 ADL      -->
    <!-- failures around json11 + std::wstring without a using-declaration.     -->
    <!-- See VENDORING_NOTES.md.                                                -->
    <ClCompile Include="src\os\windows\NetworkSocketWinsock.cpp" />
    <ClCompile Include="src\os\windows\WindowsSpecific.cpp" />
    <ClCompile Include="src\os\windows\AudioInputWASAPI.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\os\windows\AudioInputWave.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\os\windows\AudioOutputWASAPI.cpp">
