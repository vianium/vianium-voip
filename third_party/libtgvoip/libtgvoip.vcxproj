  <PropertyGroup Label="UserMacros" />
  <PropertyGroup>
    <TargetName>Vianium.libtgvoip</TargetName>
    <IntDir>$(Platform)\$(Configuration)\libtgvoip\</IntDir>
    <!-- libopus (BSD-3-Clause, Xiph.Org) is vendored in this repo under
         third_party\libopus. $(ProjectDir) here is third_party\libtgvoip\,
         so the sibling vendor tree is one level up. The OpusRoot property
         is exposed so a downstream solution can redirect to a different
         checkout if desired, but the default ships with vianium-voip. -->
    <OpusRoot Condition="'$(OpusRoot)' == ''">$(ProjectDir)..\libopus\</OpusRoot>
  </PropertyGroup>
  <PropertyGroup>
    <SolutionPlatformOutputPrefix Condition="'$(Platform)' == 'ARM'">ARM\</SolutionPlatformOutputPrefix>
    <!-- $(ProjectDir) is third_party\libtgvoip\, so the repo root is two up. -->
    <RepositoryRoot>$(ProjectDir)..\..\</RepositoryRoot>
    <SolutionOutputSyncDir Condition="'$(SolutionDir)' == '' or '$(SolutionDir)' == '$(ProjectDir)'">$(RepositoryRoot)$(SolutionPlatformOutputPrefix)$(Configuration)\libtgvoip\</SolutionOutputSyncDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <PreprocessorDefinitions>TGVOIP_USE_CALLBACK_CRYPTO=1;TGVOIP_NO_DSP=1;NOMINMAX;_CRT_SECURE_NO_WARNINGS;WINAPI_FAMILY=WINAPI_FAMILY_PHONE_APP;_ALLOW_KEYWORD_MACROS=1;noexcept=throw();%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)src;$(ProjectDir)src\audio;$(ProjectDir)src\os\windows;$(OpusRoot)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <AdditionalOptions>/bigobj %(AdditionalOptions)</AdditionalOptions>
      <SDLCheck>true</SDLCheck>
      <DisableSpecificWarnings>4100;4127;4244;4245;4334;4456;4457;4458;4459;4661;4996;4267;4838;%(DisableSpecificWarnings)</DisableSpecificWarnings>
      <TreatWarningAsError>false</TreatWarningAsError>
      <LanguageStandard>stdcpp14</LanguageStandard>
      <!-- CompileAsWinRT defaults to true under WP8.1 app context. We keep    -->
      <!-- it on so NetworkSocketWinsock.cpp (uses Platform::String^) and      -->
      <!-- snprintf-via-CRT (only in C++/CX mode) compile. The downside is     -->
      <!-- LNK4264 cosmetic warnings from lib.exe; safe to ignore for a static -->
      <!-- library that is consumed inside another C++/CX project.             -->
    </ClCompile>
    <Lib>
      <AdditionalDependencies>%(AdditionalDependencies)</AdditionalDependencies>
    </Lib>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
