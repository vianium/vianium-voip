    </ClCompile>
    <ClCompile Include="src\os\windows\AudioOutputWave.cpp">
      <ExcludedFromBuild>true</ExcludedFromBuild>
    </ClCompile>
    <ClCompile Include="src\os\windows\WindowsSandboxUtils.cpp">
